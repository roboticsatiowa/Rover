<?xml version="1.0" ?>
<sdf version="1.7">
  <world name="my_world">
    <!-- A light source -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Ground plane -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Include the Gazebo GUI plugin for user interface -->
    <gui>
      <camera name="user_camera">
        <pose>4.0 -4.0 4.0 0 0 0</pose>
        <view_controller>orbit</view_controller>
      </camera>
    </gui>
  </world>
</sdf>
